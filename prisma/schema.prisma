generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  origin      String
  description String
  logo        String?
  featured    Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id               Int      @id @default(autoincrement())
  name             String
  slug             String   @unique
  image            String
  brandId          Int
  type             String
  category         String
  price            Float
  shortDescription String
  longDescription  String
  primaryGoal      String
  featured         Boolean  @default(false)
  stock            Int?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  brand            Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String
  body        String
  category    String
  coverImage  String?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteContent {
  id               Int      @id @default(autoincrement())
  heroTitle        String
  heroSubtitle     String
  heroDescription  String
  heroPrimaryCta   String
  heroSecondaryCta String
  promoTitle       String
  promoText        String
  contactPhone     String
  whatsappNumber   String
  address          String
  schedule         String
  mapEmbedUrl      String?
  updatedAt        DateTime @updatedAt
}
